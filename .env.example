# Copy to .env and fill in. All backend vars are prefixed BOT_.

# --- Security (CHANGE THESE) ---
BOT_JWT_SECRET=change-me-to-a-long-random-string
# 44-char urlsafe-base64 Fernet key; leave blank to derive from JWT secret (dev only)
BOT_ENCRYPTION_KEY=

# --- Persistence (compose sets these automatically) ---
# BOT_DATABASE_URL=postgresql+asyncpg://bot:bot@db:5432/trading_bot
# BOT_REDIS_URL=redis://redis:6379/0

# --- Market data ---
BOT_DEFAULT_EXCHANGE=binanceusdm

# --- Background scanner (1 = on) ---
BOT_ENABLE_SCANNER=1
BOT_SCAN_INTERVAL_SECONDS=30

# --- Notifications ---
BOT_TELEGRAM_BOT_TOKEN=
BOT_TELEGRAM_CHAT_ID=
BOT_SMTP_HOST=
BOT_SMTP_PORT=587
BOT_SMTP_USER=
BOT_SMTP_PASSWORD=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
